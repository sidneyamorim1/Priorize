# .env.example
# Copie este arquivo como `.env` na raiz do projeto e preencha com as suas credenciais reais.

# 1. Configurações do Supabase (Banco de Dados e Autenticação de Produção)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-publica-do-supabase

# 2. Configurações do Resend (Envio Real de Alertas de E-mail via Serverless Function)
# Esta chave deve ser configurada nas variáveis de ambiente do seu servidor de hospedagem (Vercel/Netlify/etc.)
# Em ambiente de desenvolvimento local (npm run dev), o app usa automaticamente o Modo Simulado.
RESEND_API_KEY=sua-chave-da-api-do-resend
